{
  "expo": {
    "name": "GoBooking",
    "slug": "gobooking",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-1024.png",
    "scheme": "gobooking",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon-1024.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B3C5D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ci.gobooking.app",
      "icon": "./assets/icon-1024.png"
    },
    "android": {
      "package": "ci.gobooking.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B3C5D"
      }
    },
    "web": {
      "favicon": "./assets/icon-1024.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
